<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="app-layout">
  <aside class="sidebar glass-card admin-sidebar">
    <div class="sidebar-user">
      <div class="sidebar-avatar admin-av"><i class="bi bi-shield-fill"></i></div>
      <div><div class="sidebar-name"><%= user.name %></div><div class="sidebar-email admin-badge-sm">Administrator</div></div>
    </div>
    <nav class="sidebar-nav">
      <a href="/admin/dashboard" class="sidebar-link"><i class="bi bi-speedometer2"></i> Overview</a>
      <a href="/admin/users" class="sidebar-link active"><i class="bi bi-people"></i> Users</a>
      <a href="/admin/content" class="sidebar-link"><i class="bi bi-grid"></i> All Content</a>
      <div class="sidebar-divider"></div>
      <a href="/dashboard" class="sidebar-link"><i class="bi bi-arrow-left"></i> Back to App</a>
      <a href="/auth/logout" class="sidebar-link logout-link"><i class="bi bi-box-arrow-right"></i> Logout</a>
    </nav>
  </aside>

  <main class="app-main">
    <%- include('../partials/flash') %>

    <div class="admin-header">
      <div>
        <a href="/admin/users" class="back-link"><i class="bi bi-arrow-left"></i> Back to Users</a>
        <h1><%= targetUser.name %></h1>
        <p><%= targetUser.email %></p>
      </div>
      <div class="action-btns">
        <button class="btn-warning" onclick="toggleStatus('<%= targetUser._id %>')">
          <i class="bi bi-toggle-on"></i> Toggle Status
        </button>
        <form action="/admin/users/<%= targetUser._id %>/delete?_method=POST" method="POST" style="display:inline"
          onsubmit="return confirm('Permanently delete this user and all data?')">
          <button type="submit" class="btn-danger"><i class="bi bi-trash"></i> Delete User</button>
        </form>
      </div>
    </div>

    <!-- User Info Cards -->
    <div class="user-detail-grid">
      <div class="glass-card user-profile-card">
        <div class="profile-avatar-lg"><%= targetUser.name.charAt(0).toUpperCase() %></div>
        <h2><%= targetUser.name %></h2>
        <p class="profile-email"><%= targetUser.email %></p>
        <div class="profile-badges">
          <span class="role-badge role-<%= targetUser.role %>"><%= targetUser.role %></span>
          <span class="status-dot <%= targetUser.isActive ? 'active' : 'inactive' %>" id="status-<%= targetUser._id %>">
            <%= targetUser.isActive ? 'Active' : 'Inactive' %>
          </span>
        </div>
        <div class="profile-meta">
          <div><i class="bi bi-calendar3"></i> Joined <%= new Date(targetUser.createdAt).toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'}) %></div>
          <div><i class="bi bi-clock"></i> Last login: <%= targetUser.lastLogin ? new Date(targetUser.lastLogin).toLocaleString() : 'Never' %></div>
        </div>
      </div>

      <!-- Analytics -->
      <div class="user-analytics-col">
        <div class="stats-row">
          <div class="stat-card glass-card">
            <div class="stat-icon" style="--c:#a855f7"><i class="bi bi-cloud-upload"></i></div>
            <div class="stat-info">
              <div class="stat-value"><%= contents.length %></div>
              <div class="stat-label">Total Uploads</div>
            </div>
          </div>
          <div class="stat-card glass-card">
            <div class="stat-icon" style="--c:#10b981"><i class="bi bi-graph-up"></i></div>
            <div class="stat-info">
              <div class="stat-value"><%= analytics.avgScore %></div>
              <div class="stat-label">Avg Score</div>
            </div>
          </div>
        </div>

        <!-- Platform Usage -->
        <div class="glass-card">
          <h3>Platform Usage</h3>
          <% if (Object.keys(analytics.platformUsage).length > 0) { %>
            <div class="platform-bars">
              <% const total = Object.values(analytics.platformUsage).reduce((a,b) => a+b, 0); %>
              <% Object.entries(analytics.platformUsage).forEach(([plt, count]) => { %>
                <div class="platform-bar-row">
                  <span class="pb-label"><i class="bi bi-<%= plt %>"></i> <%= plt %></span>
                  <div class="pb-track">
                    <div class="pb-fill" style="width:<%= Math.round((count/total)*100) %>%"></div>
                  </div>
                  <span class="pb-count"><%= count %></span>
                </div>
              <% }) %>
            </div>
          <% } else { %><p class="text-muted">No uploads yet</p><% } %>
        </div>

        <!-- Rating Distribution -->
        <div class="glass-card">
          <h3>Content Rating Distribution</h3>
          <div class="rating-pills">
            <% ['Viral','Excellent','Good','Average','Poor'].forEach(r => { %>
              <div class="rating-dist-item">
                <span class="rating-badge rating-<%= r.toLowerCase() %>"><%= r %></span>
                <span class="rating-count"><%= analytics.ratingDist[r] || 0 %></span>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>

    <!-- Content List -->
    <div class="section-title-row mt-4">
      <h2>Content History</h2>
      <span class="badge-count"><%= contents.length %> items</span>
    </div>

    <div class="glass-card">
      <div class="admin-table-wrap">
        <table class="admin-table admin-table-full">
          <thead>
            <tr><th>Content</th><th>Platform</th><th>Type</th><th>Score</th><th>Rating</th><th>Date</th></tr>
          </thead>
          <tbody>
            <% contents.forEach(c => { %>
              <tr>
                <td><div class="tbl-name"><%= c.title.substring(0,30) %></div></td>
                <td><span class="badge-pill"><i class="bi bi-<%= c.platform %>"></i> <%= c.platform %></span></td>
                <td><span class="type-badge"><%= c.fileType %></span></td>
                <td>
                  <% if (c.analysis.status === 'completed') { %>
                    <div class="score-chip-sm">
                      <div class="sc-bar" style="width:<%= c.analysis.viralityScore %>%"></div>
                      <span><%= c.analysis.viralityScore %>/100</span>
                    </div>
                  <% } else { %>
                    <span class="status-badge status-<%= c.analysis.status %>"><%= c.analysis.status %></span>
                  <% } %>
                </td>
                <td>
                  <% if (c.analysis.overallRating) { %>
                    <span class="rating-badge rating-<%= c.analysis.overallRating.toLowerCase() %>"><%= c.analysis.overallRating %></span>
                  <% } else { %>—<% } %>
                </td>
                <td class="tbl-email"><%= new Date(c.createdAt).toLocaleDateString() %></td>
              </tr>
            <% }) %>
            <% if (contents.length === 0) { %>
              <tr><td colspan="6" class="text-muted text-center">No content yet</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<%- include('../partials/footer') %>
<script>
async function toggleStatus(id) {
  const res = await fetch(`/admin/users/${id}/toggle`, { method: 'POST' });
  const data = await res.json();
  if (data.success) {
    const el = document.getElementById(`status-${id}`);
    el.className = `status-dot ${data.isActive ? 'active' : 'inactive'}`;
    el.textContent = data.isActive ? 'Active' : 'Inactive';
  }
}
</script>
