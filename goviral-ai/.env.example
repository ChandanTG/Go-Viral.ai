MONGODB_URI=
SESSION_SECRET=

# Public URL used by Meta to fetch uploaded media.
# Required for real Facebook/Instagram publishing unless uploads are stored on Cloudinary.
PUBLIC_BASE_URL=https://your-domain.com

# Meta Graph API publishing.
META_GRAPH_VERSION=v25.0
META_ACCESS_TOKEN=your_meta_access_token
META_INSTAGRAM_USER_ID=your_insta_user_id
META_INSTAGRAM_USERNAME=your_instagram_username
META_PAGE_ID=your_fb_page_id

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
